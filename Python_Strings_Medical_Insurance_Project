#print(medical_data)

# Replacing the symbol # for $
updated_medical_data = medical_data.replace('#', '$')

#print(updated_medical_data)

# The number of records were dettermined by the number of $ in the text.
num_records = 0
for char in updated_medical_data:
	if char == '$':
		num_records += 1
print("There are {num_records} medical records in the data".format(num_records = num_records))

#Creating the lists by splitting the updated data by the ;
medical_data_split = updated_medical_data.split(';')
#print(medical_data_split)

#Separating each person's data into lists. So that each list in the new listmedical_records is [name, age, bmi, insurance_cost]
medical_records = []
for record in medical_data_split:
    listed_record = record.split(',')
    medical_records.append(listed_record)

#print(medical_records)

#Cleaning the data by stripping the spaces from the beggining and ending of the existing data.
medical_records_clean = []
for record in medical_records:
    record_clean = []
    for item in record:
        record_clean.append(item.strip())
  #Once the record_clean has every item of the record stripped and appended, the new list of the record is appended to medical_records_clean
    medical_records_clean.append(record_clean)

print(medical_records_clean)

# Examples of information that can be displayed now that the data is clean.
#for record in medical_records_clean:
  #print(record[0])

#for record in medical_records_clean:
    #record[0] = record[0].upper()
    #print(record[0])
	
#Creating lists for each individual category of data.
names = [] 
ages = [] 
bmis = [] 
insurance_costs = []

for record in medical_records_clean:
    names.append(record[0])
    ages.append(record[1])
    bmis.append(record[2])
    insurance_costs.append(record[3])

#Checking the changes
#print(names, '\n', ages, '\n', bmis, '\n', insurance_costs )

#Example of the information that can be extrapolated from the data
total_bmi = 0.0
for bmi in bmis:
    total_bmi += float(bmi)
#print(total_bmi)

average_bmi = total_bmi / len(bmis)
print("Average BMI: {average_bmi}".format(average_bmi = average_bmi))

#Another example of the information that can be shown
for i in range(len(names)):
    print(names[i] + " is " + ages[i] + " years old with a BMI of " + bmis[i] + " and an insurance cost of " + insurance_costs[i] + ".")
