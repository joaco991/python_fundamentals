def hurricanes_by_year(hurricane_dict):
    output = {}
    hurricane_years = {}
    
    for year in years:
        if year in hurricane_years:
            continue
        else: 
            index_list = []
            for i in range(len(years)):
                if years[i] == year:
                    index_list.append(i)
            hurricane_years[year] = index_list

    for year, indexes in hurricane_years.items():
        hurricane_list = []
        for i in indexes:
            hurricane_list.append(hurricane_dict[names[i]])
        output[year] = hurricane_list
            
    return output

