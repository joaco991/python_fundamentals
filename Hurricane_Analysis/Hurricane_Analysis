# Update Recorded Damages
conversion = {"M": 1000000,
             "B": 1000000000}

def rewrite_damages(list):
    updated_damages = []
    
    for element in list:
        if element == 'Damages not recorded':
            updated_damages.append(element)
        else: 
            num = float(element[:-1])
            conv = element[-1]
            num = num * conversion[conv]
            updated_damages.append(num)
            
    return updated_damages
    
