# Counting Damaged Areas

def counting_affected_areas(listed_areas):
    affected_areas = {}
    listed_locations = []
    
    for element in listed_areas:
        listed_locations += element

    for location in listed_locations:
        if location in affected_areas:
            continue
        else:
            count = 0
            for i in range(len(listed_locations)):
                if listed_locations[i] == location:
                    count += 1
            affected_areas[location] = count
    
    return affected_areas

