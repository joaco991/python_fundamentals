#Creating function thar allows to decipher a received message that was creatied by a general version of Ceasar Cipher.
import string as s

def r_cipher(message, offset = 3):
    abc = list(s.ascii_lowercase) * 2
    new_mess = []
	
    for char in message:
        if char in abc:
            i = abc.index(char)
            new_mess.append(abc[i+offset])
			
        else: new_mess.append(char)
		
    new_message = ''.join(new_mess)
    return new_message

