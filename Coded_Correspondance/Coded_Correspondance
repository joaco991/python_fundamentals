#Creating a function, that allows to cipher a new message.
def s_cipher(message, offset = 3):
    abc = list(s.ascii_lowercase)
    new_mess = []
	
    for char in message:
        if char in abc:
            i = abc.index(char)
            new_mess.append(abc[i-offset])
			
        else: new_mess.append(char)
		
    new_message = ''.join(new_mess)
    return new_message

