#Using a similar but opposite function, I can create ciphered messages. Always using a known keyword.
def s_vigenere(message, key):
    list_message = list(message)
    new_message_list = []
    
    key_list = key_message(message, key)

    list_mess_index = letters_to_index(list_message)
    list_key_message_index = letters_to_index(key_list)

    for i in range(len(list_mess_index)):
        if list_message[i] in abc:
            if list_key_message_index[i] > list_mess_index[i]:
                a = 26 + list_mess_index[i] - list_key_message_index[i]
            else: a = list_mess_index[i] - list_key_message_index[i]
            new_message_list.append(abc_2[a])
        else: new_message_list.append(list_mess_index[i])

    new_message = ''.join(new_message_list)
    return new_message


