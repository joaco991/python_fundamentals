#The Vigenere Cipher is a little harder and I had to create subfunctions not to repeat methods.
abc = list(s.ascii_lowercase)
abc_2 = list(s.ascii_lowercase) * 2

#This function creates a list, originally a list created from the message, but replacing each character for a letter of the key word, orderly.
def key_message(message, key):
    kmessage = []
    index = 0 
        
    for char in message:
        if char in abc and index < len(key):
            kmessage.append(key[index])
            index += 1
            if index == len(key):
                index = 0
        else: kmessage.append(char)
            
    return kmessage

#This function creates a list where replaces the letters of each text/message for the index in the list abc.
def letters_to_index(message):
    indexed_listed_message = []
    for char in message:        
        if char in abc:
            indexed_listed_message.append(abc.index(char))
        else: indexed_listed_message.append(char)
    return indexed_listed_message


#Using the subfunctions descripted, I created the new function r_vigenere to decipher the messages received. The key is a must.
def r_vigenere(message, key):
    list_message = list(message)
    real_message_list = []
    
    key_list = key_message(message, key)

    list_mess_index = letters_to_index(list_message)
    list_key_message_index = letters_to_index(key_list)

    for i in range(len(list_mess_index)):
        if list_message[i] in abc:
            a = list_key_message_index[i] + list_mess_index[i]
            real_message_list.append(abc_2[a])
        else: real_message_list.append(list_mess_index[i])

    real_message = ''.join(real_message_list)
    return real_message

